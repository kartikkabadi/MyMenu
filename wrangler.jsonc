{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mymonitor-site",
  "main": "./worker.js",
  "compatibility_date": "2026-07-14",
  "routes": [
    {
      "pattern": "mymonitor.kartikkabadi.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./website",
    "binding": "ASSETS"
  }
}
